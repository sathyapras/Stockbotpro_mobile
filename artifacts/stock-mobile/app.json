{
  "expo": {
    "name": "Stockbot Pro",
    "slug": "stock-mobile",
    "version": "5.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "stock-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0B14"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.stockbotpro.mobile",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0B14"
      },
      "package": "com.stockbotpro.mobile",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0ea5e9",
          "sounds": ["./assets/sounds/startup.wav"],
          "androidMode": "default",
          "androidCollapsedTitle": "Stockbot Pro"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "GANTI_DENGAN_PROJECT_ID_DARI_EAS"
      }
    }
  }
}
